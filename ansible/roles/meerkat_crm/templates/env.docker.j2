# Meerkat CRM - Docker Environment Configuration

# Security - JWT secret key (minimum 32 characters)
JWT_SECRET_KEY={{ meerkat_crm_jwt_secret }}

# Frontend URL for CORS headers
FRONTEND_URL=https://{{ meerkat_crm_domain }}

# Email configuration via Resend (https://resend.com/)
# Leave empty to disable email notifications (reminders won't be sent)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Enable the CardDav server for contact sync
CARDDAV_ENABLED=true

# Data storage paths (inside container)
DATA_PATH=/app/data
PHOTOS_PATH=/app/static/photos

# Cookie Configuration
COOKIE_SECURE=true
COOKIE_DOMAIN={{ meerkat_crm_domain }}

# JWT token expiry in hours
JWT_EXPIRY_HOURS=96

# Daily reminder notification time (HH:MM format, 24-hour)
REMINDER_TIME=06:00

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# Disable new user registration after initial setup
DISABLE_REGISTRATION=false
