{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "description": "Group all Pangolin role dependencies together",
      "groupName": "pangolin-role-dependencies",
      "matchFileNames": [
        "ansible/roles/pangolin/**",
        "ansible/roles/newt/**"
      ]
    },
    {
      "description": "Group all Immich role dependencies together",
      "groupName": "immich-role-dependencies",
      "matchFileNames": [
        "ansible/roles/immich/**",
        "compose/immich/**"
      ]
    }
  ]
}
